Bootstrap: docker
From: python:3.11-slim

%labels
    Author Abhignya Jagathpally
    Version 0.1.0
    Description Multiple Myeloma single-cell computational biology pipeline

%help
    R3-MM Pipeline: A comprehensive single-cell RNA-seq analysis pipeline
    for Multiple Myeloma patient samples.

    Usage:
        apptainer run r3-mm-pipeline.sif <command>
        apptainer exec r3-mm-pipeline.sif python -m src.data.download
        apptainer shell r3-mm-pipeline.sif

%environment
    export PYTHONUNBUFFERED=1
    export PYTHONDONTWRITEBYTECODE=1
    export PATH=/opt/conda/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%post
    # Update system
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        curl \
        wget \
        libhdf5-dev \
        pkg-config \
        graphviz \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*

    # Upgrade pip
    pip install --upgrade pip setuptools wheel

    # Install Python dependencies
    pip install \
        scanpy>=1.9.6 \
        anndata>=0.9.2 \
        scvi-tools>=1.1.2 \
        harmony-pytorch>=0.2 \
        celltypist>=1.3.0 \
        pandas>=2.0.0 \
        numpy>=1.24.0 \
        pyarrow>=14.0.0 \
        zarr>=2.16.0 \
        mlflow>=2.10.0 \
        wandb>=0.16.0 \
        dvc>=3.34.0 \
        ray[tune]>=2.8.0 \
        dask[dataframe]>=2023.12.0 \
        pytest>=7.4.0 \
        ruff>=0.1.0 \
        GEOparse>=2.0.3 \
        torch>=2.1.0 \
        lightning>=2.1.0 \
        pyyaml>=6.0 \
        pydantic>=2.0.0 \
        pydantic-settings>=2.0.0 \
        scikit-learn>=1.3.0 \
        scipy>=1.11.0 \
        matplotlib>=3.8.0 \
        seaborn>=0.13.0 \
        umap-learn>=0.5.3 \
        leidenalg>=0.10.0 \
        requests>=2.31.0 \
        aiohttp>=3.9.0 \
        tqdm>=4.66.0 \
        python-dotenv>=1.0.0

%files
    . /app

%apprun pipeline
    exec python "$@"

%apprun download
    exec python -m src.data.download "$@"

%apprun config
    exec python -m src.config "$@"

%runscript
    echo "R3-MM Pipeline Container"
    echo "======================="
    echo ""
    echo "Available commands:"
    echo "  apptainer run r3-mm-pipeline.sif download"
    echo "  apptainer run r3-mm-pipeline.sif pipeline <args>"
    echo "  apptainer exec r3-mm-pipeline.sif python -m src <module>"
    echo ""
    exec python "$@"

%startscript
    # Optional: setup script for persistent containers
    export PYTHONUNBUFFERED=1
    exec /bin/bash
