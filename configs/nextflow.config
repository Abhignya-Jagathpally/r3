// Nextflow Configuration for R3-MM Pipeline

manifest {
    name = 'r3-mm-pipeline'
    description = 'Multiple Myeloma single-cell computational biology pipeline'
    author = 'Abhignya Jagathpally'
    version = '0.1.0'
    nextflowVersion = '>=23.04.0'
    homePage = 'https://github.com/abhignya-j/r3-mm-pipeline'
}

params {
    // General parameters
    config = './configs/pipeline_config.yaml'
    outdir = './results'
    help = false
    version = false
    tracedir = "${params.outdir}/pipeline_info"

    // Enable/disable stages
    skip_download = false
    skip_qc = false
    skip_integration = false
    skip_annotation = false
    skip_evaluation = false

    // Publish mode
    publish_mode = 'copy'
    publish_dir_mode = 'copy'

    // Enable experiment tracking
    mlflow_enabled = true
    wandb_enabled = false
    dvc_enabled = true
}

// Process configuration
process {
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'terminate' }
    maxRetries = 2
    maxErrors = '-1'

    withLabel: 'download' {
        cpus = 4
        memory = '16 GB'
        time = '4 h'
        container = 'r3-mm-pipeline:latest'
    }

    withLabel: 'qc' {
        cpus = 8
        memory = '32 GB'
        time = '8 h'
        container = 'r3-mm-pipeline:latest'
    }

    withLabel: 'integration' {
        cpus = 16
        memory = '64 GB'
        time = '12 h'
        container = 'r3-mm-pipeline:latest'
    }

    withLabel: 'annotation' {
        cpus = 16
        memory = '64 GB'
        time = '12 h'
        container = 'r3-mm-pipeline:latest'
    }

    withLabel: 'evaluation' {
        cpus = 8
        memory = '32 GB'
        time = '4 h'
        container = 'r3-mm-pipeline:latest'
    }

    withLabel: 'pseudobulk' {
        cpus = 8
        memory = '32 GB'
        time = '4 h'
        container = 'r3-mm-pipeline:latest'
    }
}

// Profile configurations
profiles {
    standard {
        process.executor = 'local'
        process.cpus = 2
        process.memory = '4 GB'
    }

    hpc {
        process.executor = 'slurm'
        process.queue = 'normal'
        process.clusterOptions = '--account=default'
    }

    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }

    apptainer {
        apptainer.enabled = true
        apptainer.autoMounts = true
    }

    test {
        process.executor = 'local'
        process.cpus = 1
        process.memory = '2 GB'
    }
}

// Execution settings
executor {
    name = 'local'
    cpus = 4
    memory = '16 GB'
}

// Conda settings
conda {
    enabled = false
    useMamba = false
    createOptions = '-c conda-forge -c bioconda'
}

// Singularity settings
singularity {
    enabled = false
    autoMounts = true
    runOptions = '-B /tmp:/tmp'
}

// Docker settings
docker {
    enabled = false
    runOptions = '-u $(id -u):$(id -g) -v /tmp:/tmp'
}

// Timeline, report and trace
timeline {
    enabled = true
    file = "${params.tracedir}/execution_timeline.html"
}

report {
    enabled = true
    file = "${params.tracedir}/execution_report.html"
}

trace {
    enabled = true
    file = "${params.tracedir}/execution_trace.txt"
    fields = 'task_id,name,status,exit,submit,start,complete,duration,realtime,queue,memory,cpus'
}

dag {
    enabled = true
    file = "${params.tracedir}/pipeline_dag.html"
}

// Notification settings
notification {
    enabled = false
    to = ''
}

// Cleanup settings
cleanup = false
